rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email in ['tigerkim0124@gmail.com', 'admin@example.com']) && 
        request.auth.token.email_verified == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Posts collection (Board)
    match /posts/{postId} {
      // Anyone can read posts
      allow get, list: if true;
      
      // Allow write access (UI password protection handles access control)
      allow create: if isValidPost(incoming()) && isValidId(postId);
      allow update: if isValidPost(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'date', 'isNew', 'updatedAt'])
      );
      allow delete: if true;
    }

    function isValidPost(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 10000 &&
             (data.date == null || data.date is string) &&
             (data.category == null || (data.category is string && data.category.size() <= 50)) &&
             (data.isNew == null || data.isNew is bool) &&
             (data.updatedAt == null || data.updatedAt is timestamp);
    }

    // Admins collection - read-only for security check, only manually manageable via console or owner
    match /admins/{adminId} {
      allow get: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow list: if isAdmin();
    }
  }
}
