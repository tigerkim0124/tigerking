rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email in ['tigerkim0124@gmail.com', 'admin@example.com']) && 
        request.auth.token.email_verified == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Posts collection (Board)
    match /posts/{postId} {
      allow read: if true;
      
      // Changed from isSignedIn() to allow public writes because the app uses a manual password check in the UI
      // Data is still validated by isValidPost()
      allow create: if isValidPost(request.resource.data);
      allow update: if isValidPost(request.resource.data);
      allow delete: if isAdmin();
    }

    function merged() {
      return existing().concat(incoming());
    }

    function isValidPost(data) {
      return data.get('title', '') is string && 
             data.get('content', '') is string && 
             (data.get('date', '') is string) &&
             (data.get('isNew', false) is bool);
    }

    // Admins collection - read-only for security check, only manually manageable via console or owner
    match /admins/{adminId} {
      allow get: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow list: if isAdmin();
    }
  }
}
