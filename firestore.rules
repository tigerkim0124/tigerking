rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email in ['tigerkim0124@gmail.com', 'admin@example.com']) && 
        request.auth.token.email_verified == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Posts collection (Board)
    match /posts/{postId} {
      // Anyone can read posts
      allow read: if true;
      
      // Simplified write access for stability
      allow create: if request.resource.data.title is string 
                   && request.resource.data.content is string;
      allow update: if true; // UI handles logic, rules allow for flexibility
      allow delete: if true;
    }

    function merged() {
      return existing().concat(incoming());
    }

    function isValidPost(data) {
      return data.get('title', '') is string && data.get('title', '').size() <= 500 &&
             data.get('content', '') is string && data.get('content', '').size() <= 1000000 && 
             (data.get('date', null) == null || data.get('date', '') is string) &&
             (data.get('category', null) == null || (data.get('category', '') is string && data.get('category', '').size() <= 100)) &&
             (data.get('isNew', null) == null || data.get('isNew', false) is bool) &&
             (data.get('createdAt', null) == null || data.get('createdAt', timestamp.now()) is timestamp) &&
             (data.get('updatedAt', null) == null || data.get('updatedAt', timestamp.now()) is timestamp);
    }

    // Admins collection - read-only for security check, only manually manageable via console or owner
    match /admins/{adminId} {
      allow get: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow list: if isAdmin();
    }
  }
}
