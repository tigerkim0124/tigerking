{
  "entities": {
    "Notice": {
      "title": "Notice",
      "description": "A company notice or announcement",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the notice" },
        "content": { "type": "string", "description": "The main content of the notice" },
        "date": { "type": "string", "description": "Display date of the notice" },
        "isNew": { "type": "boolean", "description": "Whether the notice should be highlighted as new" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "date"]
    },
    "Admin": {
      "title": "Admin",
      "description": "User with administrative privileges",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/notices/{noticeId}": {
      "schema": "Notice",
      "description": "Public announcements"
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "List of authorized administrators"
    }
  }
}
